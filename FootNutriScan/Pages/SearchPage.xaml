<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.SearchPage"
    Title="Search"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="Search Food"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                AutomationProperties.Name="Search food title" />

            <SearchBar
                x:Name="FoodSearchBar"
                Placeholder="Enter food name"
                SearchButtonPressed="OnSearchPressed"
                AutomationProperties.Name="Food search input" />

            <Button
                Text="Search"
                Clicked="OnSearchClicked"
                BackgroundColor="#4CAF50"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="55"
                AutomationProperties.Name="Search button" />

            <Frame
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout Spacing="10">

                    <Label
                        x:Name="FoodNameLabel"
                        Text="Food Name"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        AutomationProperties.Name="Food name result" />

                    <Label
                        x:Name="CaloriesLabel"
                        Text="Calories: "
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Label
                        x:Name="ProteinLabel"
                        Text="Protein: "
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Label
                        x:Name="SugarLabel"
                        Text="Sugar: "
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Button
                        x:Name="SpeakButton"
                        Text="🔊 Read Aloud"
                        Clicked="OnSpeakClicked"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="45"
                        IsVisible="False"
                        AutomationProperties.Name="Read food information aloud" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>