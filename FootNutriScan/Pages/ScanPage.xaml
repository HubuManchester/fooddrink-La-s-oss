<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.ScanPage"
    Title="Scan"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="Food Scanner"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                AutomationProperties.Name="Food scanner title" />

            <Button
                Text="Take Photo"
                Clicked="OnTakePhotoClicked"
                BackgroundColor="#4CAF50"
                TextColor="White"
                HeightRequest="60"
                CornerRadius="15"
                AutomationProperties.Name="Take a photo of food" />

            <Button
                Text="Pick from Gallery"
                Clicked="OnPickPhotoClicked"
                BackgroundColor="#2196F3"
                TextColor="White"
                HeightRequest="60"
                CornerRadius="15"
                AutomationProperties.Name="Pick a photo from gallery" />

            <Frame
                BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#333333}"
                HeightRequest="300"
                CornerRadius="20"
                Padding="0">

                <Image
                    x:Name="CapturedImage"
                    Aspect="AspectFit"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Frame>

            <Label
                x:Name="PhotoStatusLabel"
                Text="No photo taken yet."
                HorizontalOptions="Center"
                TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />

            <Entry
                x:Name="ManualFoodEntry"
                Placeholder="Type food name shown in photo"
                AutomationProperties.Name="Enter food name" />

            <Button
                Text="Look Up This Food"
                Clicked="OnLookUpClicked"
                BackgroundColor="#FF9800"
                TextColor="White"
                HeightRequest="50"
                CornerRadius="15"
                AutomationProperties.Name="Look up food information" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>