<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.MealPlanPage"
    Title="Meal Plan">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label
            Text="Meal Planner"
            FontSize="30"
            FontAttributes="Bold"/>

        <Frame Padding="15">

            <VerticalStackLayout>

                <Label
                    Text="Breakfast"
                    FontAttributes="Bold"/>

                <Label Text="- Apple"/>
                <Label Text="- Milk"/>

            </VerticalStackLayout>

        </Frame>

    </VerticalStackLayout>

</ContentPage>