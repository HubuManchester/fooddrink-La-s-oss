<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.MealPlanPage"
    Title="Meal Plan"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="Meal Planner"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                AutomationProperties.Name="Meal planner title" />

            <Frame
                Padding="15"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                CornerRadius="15">
                <VerticalStackLayout>
                    <Label Text="Add Food" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                    <Entry
                        x:Name="FoodNameEntry"
                        Placeholder="e.g., Apple"
                        AutomationProperties.Name="Enter food name to add" />
                    <Entry
                        x:Name="CaloriesEntry"
                        Placeholder="Calories (kcal)"
                        Keyboard="Numeric"
                        AutomationProperties.Name="Enter calories" />
                    <Button
                        Text="Add to Plan"
                        Clicked="OnAddFoodClicked"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="45" />
                </VerticalStackLayout>
            </Frame>

            <Label
                x:Name="TotalCaloriesLabel"
                Text="Total: 0 kcal"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="#4CAF50"
                AutomationProperties.Name="Total planned calories" />

            <Label
                Text="Planned Foods:"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <CollectionView x:Name="FoodListView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,5" Padding="10"
                               BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#3A3A3A}"
                               CornerRadius="10">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding Name}"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding Calories, StringFormat='{0} kcal'}"
                                       TextColor="#4CAF50"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>