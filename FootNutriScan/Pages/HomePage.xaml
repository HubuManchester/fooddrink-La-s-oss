<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.HomePage"
    Title="Home"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="FootNutriScan"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                AutomationProperties.Name="Application title, FootNutriScan" />

            <Frame
                CornerRadius="20"
                BackgroundColor="#4CAF50"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="Welcome Back!"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="White"
                        AutomationProperties.Name="Welcome message" />

                    <Label
                        Text="Track your nutrition easily."
                        FontSize="16"
                        TextColor="White" />

                </VerticalStackLayout>

            </Frame>

            <Frame
                CornerRadius="20"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="Today's Calories"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        AutomationProperties.Name="Today's total calories" />

                    <Label
                        x:Name="CaloriesTodayLabel"
                        Text="1450 kcal"
                        FontSize="40"
                        FontAttributes="Bold"
                        TextColor="#4CAF50" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>