<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.SearchPage"
    Title="Search"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Food Nutrition Search"
                   FontSize="26" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <SearchBar x:Name="FoodSearchBar" Placeholder="Enter food name"
                       SearchButtonPressed="OnSearchPressed"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                       PlaceholderColor="{AppThemeBinding Light=Gray, Dark=LightGray}"
/>
            <Button Text="Search" Clicked="OnSearchClicked"
                    BackgroundColor="#4CAF50" TextColor="White"
                    CornerRadius="10" HeightRequest="45" />

            <Frame CornerRadius="15" BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" Padding="16"
                   IsVisible="False" x:Name="ResultFrame">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="FoodNameLabel" FontSize="22" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label x:Name="CaloriesLabel" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label x:Name="ProteinLabel" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label x:Name="SugarLabel" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Button x:Name="SpeakButton" Text="🔊 Read Aloud" Clicked="OnSpeakClicked"
                            BackgroundColor="#00BCD4" TextColor="White"
                            CornerRadius="10" HeightRequest="40" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Popular Foods" FontSize="20" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            <CollectionView x:Name="PopularFoodsView" SelectionMode="Single"
                SelectionChanged="OnPopularFoodSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,4" Padding="12"
                   BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#3A3A3A}"
                   CornerRadius="10">
                            <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="12">
                                <Label Text="{Binding Name}"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                <Label Grid.Column="1"
                           Text="{Binding Calories, StringFormat='K: {0} kcal'}"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                <Label Grid.Column="2"
                           Text="{Binding Protein, StringFormat='P: {0:F1} g'}"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                <Label Grid.Column="3"
                           Text="{Binding Sugar, StringFormat='S: {0:F1} g'}"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>