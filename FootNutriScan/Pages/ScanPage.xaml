<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.ScanPage"
    Title="Scan"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Food Scanner"
                   FontSize="26" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Button Text="Take Photo" Clicked="OnTakePhotoClicked"
                    BackgroundColor="#4CAF50" TextColor="White"
                    HeightRequest="55" CornerRadius="12" />
            <Button Text="Pick from Gallery" Clicked="OnPickPhotoClicked"
                    BackgroundColor="#00BCD4" TextColor="White"
                    HeightRequest="55" CornerRadius="12" />

            <Frame BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#333333}"
                   HeightRequest="280" CornerRadius="16" Padding="0">
                <Image x:Name="CapturedImage" Aspect="AspectFit"
                    HorizontalOptions="Fill" VerticalOptions="Fill" />
            </Frame>
            
            <Label x:Name="PhotoStatusLabel" Text="No photo taken yet."
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />

            <Entry x:Name="ManualFoodEntry" Placeholder="What food is in the photo?"
                   AutomationProperties.Name="Enter food name" 
                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                   PlaceholderColor="{AppThemeBinding Light=Gray, Dark=LightGray}"
                   />

            <Button Text="Look Up Nutrition" Clicked="OnLookUpClicked"
                    BackgroundColor="#FF9800" TextColor="White"
                    HeightRequest="50" CornerRadius="12" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>