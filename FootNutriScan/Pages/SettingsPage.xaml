<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.SettingsPage"
    Title="Settings"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Settings" FontSize="26" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Frame CornerRadius="15" BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" Padding="16">
                <HorizontalStackLayout Spacing="20">
                    <Label Text="Dark Mode" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Switch x:Name="DarkModeSwitch" Toggled="OnDarkModeToggled"
                            OnColor="#4CAF50" />
                </HorizontalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>