<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.SettingsPage"
    Title="Settings">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label
            Text="Settings"
            FontSize="30"
            FontAttributes="Bold"/>

        <Label
            Text="Dark Mode"/>

        <Switch/>

        <Label
            Text="Large Text"/>

        <Slider
            Minimum="12"
            Maximum="30"
            Value="18"/>

    </VerticalStackLayout>

</ContentPage>