<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.HomePage"
    Title="Home"
    BackgroundColor="#F5F5F5">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="FootNutriScan"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="Black" />

            <Frame
                CornerRadius="20"
                BackgroundColor="#4CAF50"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="Welcome Back!"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Track your nutrition easily."
                        FontSize="16"
                        TextColor="White" />

                </VerticalStackLayout>

            </Frame>

            <Frame
                CornerRadius="20"
                BackgroundColor="White"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="Today's Calories"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="Black" />

                    <Label
                        Text="1450 kcal"
                        FontSize="40"
                        FontAttributes="Bold"
                        TextColor="#4CAF50" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>