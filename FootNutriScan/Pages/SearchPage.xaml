<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FootNutriScan.Pages.SearchPage"
    Title="Search"
    BackgroundColor="#F5F5F5">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="20">

            <Label
                Text="Search Food"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="Black"/>

            <SearchBar
                x:Name="FoodSearchBar"
                Placeholder="Enter food name"
                SearchButtonPressed="OnSearchPressed"/>

            <Button
                Text="Search"
                Clicked="OnSearchClicked"
                BackgroundColor="#4CAF50"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="55"/>

            <Frame
                BackgroundColor="White"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout Spacing="10">

                    <Label
                        x:Name="FoodNameLabel"
                        Text="Food Name"
                        FontSize="24"
                        FontAttributes="Bold"/>

                    <Label
                        x:Name="CaloriesLabel"
                        Text="Calories: "/>

                    <Label
                        x:Name="ProteinLabel"
                        Text="Protein: "/>

                    <Label
                        x:Name="SugarLabel"
                        Text="Sugar: "/>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>